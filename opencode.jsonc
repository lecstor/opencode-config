{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build-envoy",
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "<REDACTED>"
      },
    }
  },
  "experimental": {
    "disable_paste_summary": true
  }
}